# queue-worker configuration
#
# Copy to .env and fill in your values:
#   cp .env.example .env && chmod 0600 .env && $EDITOR .env
#
# Process env always wins over .env, so `KEY=val queue-worker run` and CI/systemd
# Environment= will override anything here.

# Required for the HTTP usage backend (Phase 1+).
# Find this in your browser: claude.ai → DevTools → Application → Cookies →
# https://claude.ai → sessionKey (starts with sk-ant-).
CLAUDE_SESSION_KEY=

# Optional: pin a specific organization UUID. Multi-org accounts only — if unset,
# queue-worker uses the first org returned by /api/organizations.
# CLAUDE_ORG_UUID=

# Optional: usage backend. Default: auto (HTTP if key set, else Playwright).
# Values: auto | http | playwright
# QUEUE_WORKER_USAGE_BACKEND=auto

# Optional: web dashboard password. If unset, dashboard has no auth (loopback only).
# QUEUE_WORKER_PASSWORD=
