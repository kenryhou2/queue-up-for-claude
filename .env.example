# queue-worker configuration
#
# Copy to .env and fill in your values:
#   cp .env.example .env && chmod 0600 .env && $EDITOR .env
#
# Process env always wins over .env, so `KEY=val queue-worker run` and CI/systemd
# Environment= will override anything here.

# REQUIRED. Find this in your browser:
#   claude.ai → DevTools → Application → Cookies → https://claude.ai → sessionKey
# Starts with sk-ant-.
CLAUDE_SESSION_KEY=

# Optional: pin a specific organization UUID. Required if your account has more
# than one org — otherwise the HTTP backend refuses to auto-pick rather than
# risk querying the wrong one.
# CLAUDE_ORG_UUID=

# Optional: web dashboard password. If unset, dashboard has no auth (loopback only).
# QUEUE_WORKER_PASSWORD=
