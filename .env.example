# codex-queue configuration
#
# Copy to .env and fill in your values:
#   cp .env.example .env && chmod 0600 .env && $EDITOR .env
#
# Process env always wins over .env, so `KEY=val codex-queue run` and
# CI/systemd Environment= will override anything here.

# ── Usage backend ────────────────────────────────────────────────────────────
#
# Choose ONE of the two backends below.

# Backend selector: "command" (default) or "codex_http".
# CODEX_QUEUE_USAGE_BACKEND=command

# --- Backend A: local command (default) ---
# REQUIRED when CODEX_QUEUE_USAGE_BACKEND=command (or unset).
# Command is split with shlex and executed without a shell. It must print JSON:
#   {"used_pct": 71, "reset_minutes": 58}
#CODEX_QUEUE_USAGE_COMMAND=

# Optional: seconds before the usage command is considered stuck.
# CODEX_QUEUE_USAGE_TIMEOUT_SECONDS=30

# --- Backend B: ChatGPT Codex cloud HTTP (built-in) ---
# Fetches from https://chatgpt.com/codex/cloud/settings/analytics#usage
# Set CODEX_QUEUE_USAGE_BACKEND=codex_http to activate this backend.
#
# How to get your session token:
#   1. Log in at https://chatgpt.com
#   2. Open DevTools → Application → Cookies → chatgpt.com
#   3. Copy the value of __Secure-next-auth.session-token
#
# Store it here OR in ~/.config/queue-worker/chatgpt_session_token (chmod 0600).
# CODEX_QUEUE_CHATGPT_SESSION_TOKEN=

# Optional: override the Codex usage API URL if the default path changes.
# Inspect DevTools → Network on the analytics page to find the current endpoint.
# CODEX_QUEUE_CHATGPT_USAGE_URL=https://chatgpt.com/backend-api/wham/usage

# ── Other settings ────────────────────────────────────────────────────────────

# Optional: absolute path to the Codex CLI used for queued task execution.
# Useful for systemd/web server processes whose PATH differs from your shell.
# Find it with: command -v codex
# CODEX_QUEUE_CODEX_BIN=/home/you/.local/bin/codex

# Optional: bypass Codex's own Linux sandbox for queued executions.
# Use only when the queue process already runs inside a dedicated user,
# container, VM, or other isolation boundary. This avoids nested bubblewrap
# failures such as "bwrap: loopback: Failed RTM_NEWADDR".
# CODEX_QUEUE_CODEX_BYPASS_SANDBOX=0

# Optional: fallback window for `--run-policy next_session` when no trusted
# usage check is available.
# CODEX_QUEUE_FALLBACK_WINDOW_MINUTES=300

# Optional: web dashboard password. If unset, dashboard has no auth (loopback only).
# CODEX_QUEUE_PASSWORD=
